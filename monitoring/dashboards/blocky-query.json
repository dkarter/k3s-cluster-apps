                      "rawSql": "SELECT t.question_name as metric, count(*) as value from log_entries t \n  WHERE $__timeFilter(t.request_Ts) and \n  ('${response_type:csv}' = '' or t.response_type = ANY(string_to_array('${response_type:csv}', ','))) and \n  ('${client_name:csv}' = '' or t.client_name = ANY(string_to_array('${client_name:csv}', ','))) and \n  (length(${question:sqlstring}) = 0 or POSITION(lower(${question:sqlstring}) IN t.question_name) > 0) \n  group by t.question_name order by count(*) desc limit 20",
                      "select": [
                        [
                          {
                            "params": [
                              "value"
                            ],
                            "type": "column"
                          }
                        ]
                      ],
                      "table": "log_entries",
                      "timeColumn": "request_ts",
                      "where": []
                    },
