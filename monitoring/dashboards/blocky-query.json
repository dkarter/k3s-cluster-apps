          "rawQuery": true,
          "rawSql": "SELECT max(t.request_ts) AS time,\n       case when t.reason  like 'BLOCKED%' then SPLIT_PART(SPLIT_PART(t.reason,'(',-1), ')',1) else '' end AS metric,\n       count(t.reason) AS cnt\nFROM log_entries t\nWHERE t.response_type ='BLOCKED'\n  AND $__timeFilter(t.request_Ts)\n  AND ('${client_name:csv}' = '' or t.client_name = ANY(string_to_array('${client_name:csv}', ',')))\n  AND (length(${question:sqlstring}) = 0 or POSITION(lower(${question:sqlstring}) IN t.question_name) > 0)\nGROUP BY 2\nORDER BY time",
          "refId": "A",
          "select": [
